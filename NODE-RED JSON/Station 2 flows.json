    {
        "id": "19550f94c81a42a0",
        "type": "function",
        "z": "7dff91e08eb26027",
        "g": "d994916e7bf069ef",
        "name": "function to mysql",
        "func": "// The JSON node before this has already converted the string to an object\n// Access the data using msg.payload\nvar sensorID = msg.payload.sensor_key;\nvar readingValue = msg.payload.value;\n\n// Build the SQL Insert Query\n// We use NOW() so the database records the exact time it receives the data\nmsg.topic = \"INSERT INTO sensor_data (sensor_ID, log_time, data_value) VALUES (\" \n            + sensorID + \", NOW(), \" + readingValue + \");\";\n\nreturn msg;",
