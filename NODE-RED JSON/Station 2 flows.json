        "name": "Occupancy",
        "order": 35,
        "width": "0",
        "height": "0",
        "format": "<div\n    style=\"text-align:center; padding:15px; border-radius:12px; background:#1e1e1e; color:white; font-size:1.4em; box-shadow:0 0 10px rgba(0,0,0,0.4);\">\n\n    <div ng-if=\"msg.payload == 1\">\n        <div style=\"font-size:3em; animation: pulse 1.5s infinite;\">\n            👷🏻‍♂️\n        </div>\n        <div style=\"margin-top:5px; font-weight:bold; color:#4CAF50;\">\n            INSPECTION IN PROCESS\n        </div>\n    </div>\n\n    <div ng-if=\"msg.payload == 0\">\n        <div style=\"font-size:3em; opacity:0.5;\">\n            🚫\n        </div>\n        <div style=\"margin-top:5px; font-weight:bold; color:#F44336;\">\n            NO OCCUPANCY\n        </div>\n    </div>\n\n</div>\n\n<style>\n    @keyframes pulse {\n        0% {\n            transform: scale(1);\n        }\n\n        50% {\n            transform: scale(1.15);\n        }\n\n        100% {\n            transform: scale(1);\n        }\n    }\n</style>",
