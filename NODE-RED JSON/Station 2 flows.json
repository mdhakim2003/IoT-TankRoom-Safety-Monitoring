    {
        "id": "efafd0d8938268b0",
        "type": "function",
        "z": "7dff91e08eb26027",
        "g": "d058a49083bc0833",
        "name": "function For Monitoring",
        "func": "// The JSON node has already converted the MQTT string to a JS Object\nvar sensorID = msg.payload.sensor_key;\nvar readingValue = msg.payload.value;\n\n// Define the 4 possible outputs\nvar outOccupancy = null; // Output 1\nvar outDistance  = null; // Output 2\nvar outSmoke     = null; // Output 3\nvar outFan       = null; // Output 4\n\n// Route the value based on the ID defined in your Python SENSORS dictionary\nif (sensorID === 121) {\n    outOccupancy = { payload: readingValue };\n} else if (sensorID === 122) {\n    outDistance = { payload: readingValue };\n} else if (sensorID === 123) {\n    outSmoke = { payload: readingValue };\n} else if (sensorID === 124) {\n    outFan = { payload: readingValue };\n}\n\n// Return the array in the order of the output pins\nreturn [outOccupancy, outDistance, outSmoke, outFan];",
        "outputs": 4,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 840,
        "y": 520,
